LIVEKIT_URL=wss://your-livekit-cloud-url.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
GOOGLE_API_KEY=
SARVAM_API_KEY=
OPENROUTER_API_KEY=
LIVEKIT_AGENT_NAME=rto-recovery-agent

# ── Outbound Telephony ───────────────────────────────────────────────────────
OUTBOUND_CALL_PROVIDER=vapi          # vapi | livekit
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_SHOP_NAME=your-store.myshopify.com
APP_URL=https://rto-livekit-node-production.up.railway.app
SHOPIFY_ACCESS_TOKEN=             # filled after OAuth install
SHOPIFY_API_KEY=                  # from Shopify Dev Dashboard → RTO Agent → Settings
SHOPIFY_API_SECRET=               # from Shopify Dev Dashboard → RTO Agent → Settings
SHOPIFY_WEBHOOK_SECRET=           # any strong random string — must match Shopify webhook config

# ── RTO Configuration ────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=hi-IN            # hi-IN | gu-IN | ta-IN | te-IN
WEBHOOK_PORT=3000                 # must match Railway public port
SIMULATION_MODE_ENABLED=true      # true for local simulator UI/routes
